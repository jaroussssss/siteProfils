{
  "permissions": {
    "allow": [
      "Bash(git status)", "Bash(git log *)", "Bash(git diff *)", "Bash(git pull *)",
      "Bash(node *)", "Bash(npm *)", "Bash(npx *)",
      "Bash(ls *)", "Bash(cat *)", "Bash(echo *)", "Bash(mkdir *)", "Bash(cp *)",
      "Bash(curl *)", "Bash(open *)",
      "mcp__playwright__*", "mcp__context7__*"
    ],
    "deny": [
      "Bash(rm -rf /)", "Bash(sudo *)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/auto-update.sh",
            "timeout": 8000
          }
        ]
      }
    ]
  }
}
