{
  "permissions": {
    "allow": [
      "Bash(git status)", "Bash(git status *)",
      "Bash(git log)", "Bash(git log *)",
      "Bash(git diff)", "Bash(git diff *)",
      "Bash(git pull)", "Bash(git pull *)",
      "Bash(git add *)", "Bash(git commit *)",
      "Bash(npm install)", "Bash(npm install *)",
      "Bash(npm test)", "Bash(npm test *)",
      "Bash(npm run *)",
      "Bash(npm ls)", "Bash(npm ls *)",
      "Bash(npx claude-flow*)",
      "Bash(npx ruflo*)", "Bash(npx -y ruflo*)",
      "Bash(node *)",
      "Bash(ls)", "Bash(ls *)",
      "Bash(cat *)", "Bash(echo *)",
      "Bash(mkdir)", "Bash(mkdir *)",
      "Bash(pwd)", "Bash(whoami)",
      "mcp__playwright__*", "mcp__context7__*"
    ],
    "deny": [
      "Bash(rm -rf *)", "Bash(rm -fr *)", "Bash(rm -r *)",
      "Bash(sudo *)",
      "Bash(curl *)", "Bash(wget *)",
      "Bash(eval *)", "Bash(sh -c *)", "Bash(bash -c *)",
      "Bash(chmod 777 *)", "Bash(chmod -R 777 *)",
      "Bash(scp *)", "Bash(ssh *)",
      "Bash(npm publish *)", "Bash(npm config set *)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/auto-update.sh",
            "timeout": 8000
          }
        ]
      }
    ]
  }
}
