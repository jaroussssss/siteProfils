<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Page admin</title>
    <link rel="stylesheet" href="/css/admin.css" />
    <!-- Chart.js via CDN -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  </head>
  <body>
    <div class="app-container">
      <!-- Sidebar -->
      <aside class="sidebar">
        <h2>Modèles</h2>
        <ul id="modelsList" class="models-list">
          <% models.forEach(function(m) { %>
            <li class="models-item" data-name="<%= m.name %>"><%= m.name %></li>
          <% }); %>
        </ul>
        <button id="createModelBtn" class="btn btn-primary">Créer un nouveau modèle</button>
      </aside>

      <!-- Main content -->
      <main class="main">
        <header class="topbar">
          <div class="controls">
            <label for="rangeSelect">Temporalité</label>
            <select id="rangeSelect">
              <option value="day">24h</option>
              <option value="day">48h</option>
              <option value="day">72h</option>
              <option value="week">Une semaine</option>
              <option value="month" selected>Un mois</option>
            </select>
            <button id="createLinkBtn" class="btn btn-primary">Nouveau lien</button>
          </div>
          <div id="activeModelName" class="active-model">Sélectionnez un modèle</div>
        </header>

        <section class="block">
          <h3>Liste des liens</h3>
          <table class="table" aria-label="Liste des liens">
            <thead>
              <tr>
                <th>Sélection</th>
                <th>URL publique</th>
                <th>Modifier</th>
                <th>Supprimer</th>
              </tr>
            </thead>
            <tbody id="linksListBody"></tbody>
          </table>
        </section>

        <section class="block">
          <h3>Visites par liens</h3>
          <table class="table" aria-label="Visites par lien">
            <thead>
              <tr>
                <th>Lien</th>
                <th>Visites</th>
                <th>Pourcentage</th>
              </tr>
            </thead>
            <tbody id="linksTableBody"></tbody>
          </table>
          <canvas id="linksChart" width="800" height="300"></canvas>
        </section>

        <section class="block">
          <h3>Visites par pays</h3>
          <table class="table" aria-label="Visites par pays">
            <thead>
              <tr>
                <th>Pays</th>
                <th>Visites</th>
                <th>Pourcentage</th>
              </tr>
            </thead>
            <tbody id="countriesTableBody"></tbody>
          </table>
          <canvas id="countriesChart" width="800" height="300"></canvas>
        </section>

        <section class="block">
          <h3>Conversions</h3>
          <table class="table" aria-label="Visites par pays">
            <thead>
              <tr>
                <th>Type</th>
                <th>Clicks</th>
                <th>Pourcentage</th>
              </tr>
            </thead>
            <tbody id="conversionsTableBody"></tbody>
          </table>
          <canvas id="conversionsChart" width="800" height="300"></canvas>
        </section>

      </main>
    </div>

    <script src="/js/admin.js"></script>
  </body>
  </html>